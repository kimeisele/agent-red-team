{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/kimeisele/agent-red-team/schemas/audit-request.v1.schema.json",
  "title": "Audit Request",
  "description": "A request-driven audit of a Federation repository by Agent Red Team.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "target_repository",
    "requester",
    "scope",
    "audit_types",
    "permitted_methods",
    "disclosure_channel",
    "point_of_contact",
    "authorization_statement",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Schema version identifier."
    },
    "request_id": {
      "type": "string",
      "description": "Stable unique identifier for this audit request.",
      "minLength": 1
    },
    "target_repository": {
      "type": "string",
      "description": "Full owner/repo to be audited.",
      "pattern": "^[a-zA-Z0-9._-]+/[a-zA-Z0-9._-]+$"
    },
    "target_ref": {
      "type": "string",
      "description": "Specific branch or commit SHA to audit. Defaults to the default branch if omitted."
    },
    "requester": {
      "type": "string",
      "description": "Attributable Federation node or human operator.",
      "minLength": 1
    },
    "scope": {
      "type": "array",
      "description": "Files, subsystems, or concerns in scope.",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "exclusions": {
      "type": "array",
      "description": "Files or subsystems explicitly excluded.",
      "items": { "type": "string" }
    },
    "audit_types": {
      "type": "array",
      "description": "Types of audit to perform.",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "code-review",
          "governance-gap-analysis",
          "workflow-audit",
          "architecture-risk-assessment",
          "dependency-and-supply-chain",
          "secrets-exposure",
          "federation-contracts"
        ]
      }
    },
    "permitted_methods": {
      "type": "array",
      "description": "Non-destructive methods permitted for this audit.",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "static-analysis",
          "workflow-inspection",
          "governance-review",
          "safe-reproduction",
          "dependency-analysis",
          "federation-contract-validation"
        ]
      }
    },
    "excluded_methods": {
      "type": "array",
      "description": "Methods explicitly excluded even if normally permitted.",
      "items": { "type": "string" }
    },
    "disclosure_channel": {
      "type": "string",
      "description": "Channel for reporting findings.",
      "enum": [
        "public-issue",
        "private-security-advisory",
        "confidential-report"
      ]
    },
    "point_of_contact": {
      "type": "string",
      "description": "Who receives findings and coordinates remediation.",
      "minLength": 1
    },
    "authorization_statement": {
      "type": "string",
      "description": "Explicit statement that this request authorises the described audit scope.",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of request creation.",
      "format": "date-time"
    }
  }
}
